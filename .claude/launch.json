{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laghu Parashari API (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Frontend (Static HTML)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000", "--directory", "frontend"],
      "port": 3000
    }
  ]
}
